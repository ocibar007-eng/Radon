API_KEY=AIza...
# GEMINI_API_KEY=AIza... (alias for API_KEY, optional)
# GEMINI_ENABLE_THINKING=1 (optional, only if your model supports thinking)
OPENAI_API_KEY=sk-...
OPENAI_MODEL_COMPARISON=gpt-5.2-2025-12-11
OPENAI_MODEL_IMPRESSION=gpt-5.2-2025-12-11
OPENAI_MODEL_RENDERER=gpt-5.2-2025-12-11
# OpenAI Draft (Pré-Laudo IA)
# OPENAI_DRAFT_ENABLED=1
# OPENAI_DRAFT_MODEL=gpt-5.2-2025-12-11
# OPENAI_DRAFT_CORRECTION_MODEL=gpt-5.2-2025-12-11
# OPENAI_DRAFT_MAX_TOKENS=8192
# OPENAI_DRAFT_REASONING_EFFORT=high
# OPENAI_DRAFT_INPUT_USD_PER_M=0
# OPENAI_DRAFT_OUTPUT_USD_PER_M=0
# OPENAI_DRAFT_USAGE_LOG_PATH=C:/temp/radon-lite/openai-draft-usage.jsonl
# Frontend draft engine: gpt (default) | claude
# VITE_DRAFT_ENGINE=gpt
# VITE_DRAFT_REASONING_EFFORT=high
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_REPORT_ENABLED=0 (optional: disable Claude endpoints)
# CLAUDE_MODEL=claude-opus-4-6
# CLAUDE_CORRECTION_MODEL=claude-sonnet-4-5
# CLAUDE_MONTHLY_BUDGET_BRL=1000
# ANTHROPIC_ADMIN_API_KEY=sk-ant-admin-... (required for /api/admin/anthropic-usage)
# Pipeline Sandbox
# VITE_PIPELINE_URL=https://pipeline.seudominio.com
# VITE_CALC_URL=https://calculator.seudominio.com
# PIPELINE_TOKEN=exemplo
# FIREBASE_API_KEY=...
# FIREBASE_AUTH_DOMAIN=...
# FIREBASE_PROJECT_ID=...
# FIREBASE_STORAGE_BUCKET=...
# FIREBASE_MESSAGING_SENDER_ID=...
# FIREBASE_APP_ID=...
